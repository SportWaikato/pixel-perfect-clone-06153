# Copy to .env and fill in real values. Never commit .env.
# The VITE_-prefixed variables are bundled into client-side code — only ever
# put publishable/anon keys there, never secrets.

# Supabase (anon/publishable key is safe client-side)
SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"

# Supabase service role key — SERVER ONLY, bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend (transactional email) — SERVER ONLY secret
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email + app URLs
VITE_FROM_EMAIL="noreply@example.com"
VITE_APP_URL="https://your-app-url.example.com"

# Google AI / Gemini (badge + assembly icon generation) — SERVER ONLY secret
GOOGLE_AI_API_KEY="your-gemini-api-key"
